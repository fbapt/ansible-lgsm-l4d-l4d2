#!/usr/sbin/nft -f
flush ruleset

define ssh_port = {{ configure_nftables_ssh_port }}
define games_ports = { {{ configure_nftables_games_servers_ports }} }

table inet filter {

    chain input {
        type filter hook input priority filter;
        policy drop;

        # Loopback
        iif "lo" accept

        # Connexions établies
        ct state established,related accept

        # Paquets invalides
        ct state invalid drop

        # SSH
        tcp dport $ssh_port ct state new counter accept

        # UDP Game servers
        udp dport $games_ports counter accept

        # ICMP
        ip protocol icmp icmp type {
            destination-unreachable,
            time-exceeded,
            parameter-problem
        } counter accept

        ip protocol icmp icmp type echo-request limit rate 5/second counter accept

        # ICMPv6
        ip6 nexthdr ipv6-icmp icmpv6 type {
            destination-unreachable,
            packet-too-big,
            time-exceeded,
            parameter-problem,
            nd-neighbor-solicit,
            nd-neighbor-advert,
            nd-router-solicit,
            nd-router-advert
        } counter accept
    }

    chain forward {
        type filter hook forward priority filter;
        policy drop;
    }

    chain output {
        type filter hook output priority filter;
        policy accept;
    }
}
